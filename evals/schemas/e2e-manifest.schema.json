{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/goal-draft-policy/e2e-manifest.schema.json",
  "type": "object",
  "required": ["schema_version", "run_id", "authority", "result_path", "result_sha256", "note"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "2.0-e2e-manifest"},
    "run_id": {"type": "string"},
    "authority": {"enum": ["initial", "revision", "superseded", "failed", "contaminated", "inconclusive"]},
    "result_path": {"type": "string"},
    "result_sha256": {"pattern": "^[a-f0-9]{64}$"},
    "note": {"type": "string"}
  }
}
